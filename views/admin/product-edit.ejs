<div class="topline">
  <h1>Edit: <%= product.name %></h1>
  <div><a class="btn btn-outline btn-sm" href="/admin/products">← Products</a> <a class="btn btn-outline btn-sm" href="/products/<%= product._catSlug %>/<%= product.slug %>" target="_blank">View ↗</a></div>
</div>
<% if (saved) { %><div class="panel" style="background:#eafaf0;border-color:#b9e6cb;color:#1f7a47">✓ Saved.</div><% } %>

<div class="grid2" style="align-items:start">
  <div class="panel">
    <h2>Details</h2>
    <form action="/admin/products/<%= product.id %>" method="POST">
      <div class="field"><label>Name</label><input type="text" name="name" value="<%= product.name %>"></div>
      <div class="field"><label>Short description</label><textarea name="short_desc"><%= product.short_desc %></textarea></div>
      <div class="field"><label>Long description</label><textarea name="long_desc" style="min-height:120px"><%= product.long_desc %></textarea></div>
      <div class="grid2">
        <div class="field"><label>Price mode</label>
          <select name="price_mode">
            <option value="on_request" <%= product.price_mode==='on_request'?'selected':'' %>>On request</option>
            <option value="fixed" <%= product.price_mode==='fixed'?'selected':'' %>>Fixed price</option>
          </select>
        </div>
        <div class="field"><label>Price (display)</label><input type="text" name="price" value="<%= product.price || '' %>"></div>
        <div class="field"><label>MOQ</label><input type="text" name="moq" value="<%= product.moq || '' %>"></div>
        <div class="field"><label>Lead time</label><input type="text" name="lead_time" value="<%= product.lead_time || '' %>"></div>
      </div>
      <div class="field"><label>Status</label>
        <select name="status"><option value="active" <%= product.status==='active'?'selected':'' %>>Active</option><option value="hidden" <%= product.status==='hidden'?'selected':'' %>>Hidden</option></select>
      </div>
      <div class="field"><label>SEO title</label><input type="text" name="seo_title" value="<%= product.seo_title || '' %>"></div>
      <div class="field"><label>SEO meta description</label><textarea name="seo_meta"><%= product.seo_meta || '' %></textarea></div>
      <button class="btn btn-primary" type="submit">Save changes</button>
    </form>
  </div>

  <div>
    <div class="panel">
      <h2>Images (local storage)</h2>
      <div class="img-grid">
        <% product.images.forEach(function(img){ %>
          <div class="item">
            <img src="<%= img.path %>" alt="<%= img.alt %>">
            <div class="ctl">
              <% if (img.is_primary) { %><span class="badge b-Won">Primary</span>
              <% } else { %>
                <form action="/admin/products/<%= product.id %>/images/<%= img.id %>/primary" method="POST"><button class="btn btn-outline btn-sm" type="submit">Set primary</button></form>
              <% } %>
              <form action="/admin/products/<%= product.id %>/images/<%= img.id %>/delete" method="POST" onsubmit="return confirm('Delete this image?')"><button class="btn btn-outline btn-sm" type="submit">✕</button></form>
            </div>
          </div>
        <% }) %>
      </div>
      <form action="/admin/products/<%= product.id %>/images" method="POST" enctype="multipart/form-data" style="margin-top:16px">
        <div class="field"><label>Upload image (JPG/PNG/WebP, max 8 MB)</label><input type="file" name="image" accept="image/*" required></div>
        <div class="field"><label>Alt text</label><input type="text" name="alt" placeholder="<%= product.name %> — D Cam Engineering"></div>
        <button class="btn btn-primary btn-sm" type="submit">Upload</button>
      </form>
    </div>

    <div class="panel">
      <h2>Lead-form fields</h2>
      <p class="muted" style="font-size:.85rem">These product-specific fields appear on this product's enquiry form (defined in seed data / <code>form_fields_json</code>).</p>
      <table class="cfg-table">
        <% product.form_fields.forEach(function(f){ %>
          <tr><td><%= f.label %> <%= f.required ? '*' : '' %></td><td><%= f.type %><%= f.options ? ' — ' + f.options.join(', ') : '' %></td></tr>
        <% }) %>
      </table>
    </div>
  </div>
</div>
