<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%
    var desc = (metaDesc && metaDesc.trim()) ? metaDesc
      : 'D Cam Engineering — in-house manufacturer of high-pressure & laboratory equipment for oil & gas, EOR and geotechnical research since ' + company.established + '. Based in Ahmedabad, Gujarat, India. Exports worldwide.';
    var canonical = siteUrl + (currentPath === '/' ? '' : currentPath);
    var ogImage = siteUrl + '/og-image.png';
  %>
  <title><%= title %></title>
  <meta name="description" content="<%= desc %>">
  <% if (noindex) { %><meta name="robots" content="noindex,nofollow"><% } else { %><meta name="robots" content="index,follow"><% } %>
  <link rel="canonical" href="<%= canonical %>">
  <meta name="theme-color" content="#062a46">

  <!-- Favicons / app icons -->
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="<%= company.name %>">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="<%= desc %>">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:image" content="<%= ogImage %>">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content="en_IN">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title %>">
  <meta name="twitter:description" content="<%= desc %>">
  <meta name="twitter:image" content="<%= ogImage %>">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">

  <!-- Organization structured data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "<%= company.name %>",
    "url": "<%= siteUrl %>",
    "logo": "<%= siteUrl %>/img/logo-horizontal.png",
    "image": "<%= ogImage %>",
    "description": "<%= desc %>",
    "foundingDate": "<%= company.established %>",
    "email": "<%= company.email %>",
    "telephone": "<%= company.phone %>",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "<%= company.address %>",
      "addressLocality": "Ahmedabad",
      "addressRegion": "Gujarat",
      "addressCountry": "IN"
    }
  }
  </script>
</head>
<body>
  <%- include('../partials/header') %>
  <main>
    <%- body %>
  </main>
  <%- include('../partials/footer') %>
  <a class="wa-float" href="https://wa.me/<%= whatsappNumber %>?text=<%= encodeURIComponent('Hi D Cam Engineering, I have an enquiry.') %>" target="_blank" aria-label="Chat on WhatsApp">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.041zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
  </a>
  <script src="/js/main.js"></script>
</body>
</html>
