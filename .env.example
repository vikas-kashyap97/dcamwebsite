# ─────────────────────────────────────────────────────────────
# D Cam Engineering — environment configuration
# Copy this file to ".env" and fill in real values.
# NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────────────────

# Server
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string

# Public site URL (used in emails / links)
SITE_URL=http://localhost:3000

# ── SMTP (lead notification + buyer acknowledgement) ──
# Use an authenticated transactional relay (domain mailbox, Zoho, Brevo, SES…)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false           # true for port 465, false for 587 (STARTTLS)
SMTP_USER=website@dcamengineering.com
SMTP_PASS=your-smtp-password
FROM_EMAIL="D Cam Engineering <website@dcamengineering.com>"

# Where new enquiries are sent (the founder). Comma-separate for multiple.
FOUNDER_EMAIL=dharmendra@dcamengineering.com

# ── WhatsApp click-to-chat ──
# International format, digits only, no + or spaces. Candidate from data: 919687930390
WHATSAPP_NUMBER=919687930390

# ── First admin (owner) login — created by `npm run init-db` ──
ADMIN_EMAIL=admin@dcamengineering.com
ADMIN_PASSWORD=ChangeMe123!
